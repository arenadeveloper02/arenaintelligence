datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Setting {
  id           String   @id @default(cuid())
  userId       String   @unique
  openaiApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Execution {
  id        String   @id @default(cuid())
  userId    String
  agentName String
  input     String
  output    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, agentName])
}

model AgentJob {
  id          String    @id @default(cuid())
  userId      String
  agentName   String
  input       String
  status      String    @default("queued")
  progress    Int       @default(0)
  step        String?
  error       String?
  executionId String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @default(now()) @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  category    String
  title       String
  message     String
  read        Boolean  @default(false)
  agentSlug   String?
  executionId String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}
