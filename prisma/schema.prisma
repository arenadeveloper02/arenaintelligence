datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  setting       Setting?
  executions    Execution[]
  notifications Notification[]
  agentJobs     AgentJob[]
}

model Setting {
  id           String   @id @default(cuid())
  userId       String   @unique
  openaiApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Execution {
  id        String   @id @default(cuid())
  userId    String
  agentName String
  input     String
  output    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentName])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  category    String
  title       String
  message     String
  read        Boolean  @default(false)
  agentSlug   String?
  executionId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AgentJob {
  id          String    @id @default(cuid())
  userId      String
  agentName   String
  input       String
  status      String    @default("queued")
  progress    Int       @default(0)
  step        String?
  error       String?
  executionId String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
}
